# ============================================================
# CONFIGURACIÓN DEL AGENTE DE IA PARA OPTIMIZACIÓN DE RED UNIFI
# ============================================================
# Copia este archivo como ".env" y completa con tus valores reales.
# NUNCA subas el archivo .env a un repositorio de código.
# ============================================================

# --- Controlador UniFi ---
# IP o hostname del controlador (UDM Pro, Cloud Key, etc.)
# Ejemplo: 192.168.1.1 o unifi.local
UNIFI_HOST=192.168.1.1

# Puerto HTTPS del controlador (por defecto 443 para UDM Pro, 8443 para Cloud Key)
UNIFI_PORT=443

# Credenciales de un usuario LOCAL del controlador UniFi.
# ⚠️ Se recomienda crear una cuenta de administrador dedicada para la API.
UNIFI_USERNAME=api_admin
UNIFI_PASSWORD=tu_password_seguro

# Nombre del sitio UniFi (por defecto "default").
UNIFI_SITE=default

# Tipo de controlador: "udm" para UDM/UDM Pro/UDM SE, "cloudkey" para Cloud Key / Software.
# Esto determina el prefijo de los endpoints de la API.
UNIFI_CONTROLLER_TYPE=udm

# Desactivar la verificación SSL para conexiones locales (true/false).
# Necesario si el controlador usa un certificado autofirmado.
UNIFI_VERIFY_SSL=false

# Modo Simulación / Dry Run (true/false)
# Si es true, el agente simula las acciones correctivas (como reiniciar) sin realizarlas de verdad.
DRY_RUN=false

# --- API de IA (Google Gemini) ---
# Obtén tu API Key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_de_gemini

# Modelo de Gemini a utilizar.
GEMINI_MODEL=gemini-2.5-flash
