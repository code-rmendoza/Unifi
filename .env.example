# ============================================================
# CONFIGURACIÓN DEL AGENTE DE IA PARA OPTIMIZACIÓN DE RED UNIFI
# ============================================================
# Copia este archivo como ".env" y completa con tus valores reales.
# NUNCA subas el archivo .env a un repositorio de código.
# ============================================================

# --- Entorno ---
# "development" para local, "production" para despliegue.
ENVIRONMENT=development

# --- Controlador UniFi ---
# IP o hostname del controlador (UDM Pro, Cloud Key, etc.)
# Ejemplo: 192.168.1.1 o unifi.local
UNIFI_HOST=192.168.1.1

# Puerto HTTPS del controlador (por defecto 443 para UDM Pro, 8443 para Cloud Key)
UNIFI_PORT=443

# Credenciales de un usuario LOCAL del controlador UniFi.
# ⚠️ Se recomienda crear una cuenta de administrador dedicada para la API.
UNIFI_USERNAME=api_admin
UNIFI_PASSWORD=tu_password_seguro

# Nombre del sitio UniFi (por defecto "default").
UNIFI_SITE=default

# Tipo de controlador: "udm" para UDM/UDM Pro/UDM SE, "cloudkey" para Cloud Key / Software.
# Esto determina el prefijo de los endpoints de la API.
UNIFI_CONTROLLER_TYPE=udm

# Desactivar la verificación SSL para conexiones locales (true/false).
# Necesario si el controlador usa un certificado autofirmado.
UNIFI_VERIFY_SSL=false

# Modo Simulación / Dry Run (true/false)
# Si es true, el agente simula las acciones correctivas (como reiniciar) sin realizarlas de verdad.
DRY_RUN=false

# --- Base de datos SQLite ---
# Ruta del archivo de base de datos para la memoria histórica.
DB_PATH=historial.db

# --- API de IA (Google Gemini) ---
# Obtén tu API Key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_de_gemini

# Modelo de Gemini a utilizar.
GEMINI_MODEL=gemini-2.5-flash

# --- Autenticación de la API Web ---
# API Key para autenticar las peticiones a los endpoints de acción (diagnosticar, reiniciar, optimizar).
# Se envía en el header HTTP "X-API-Key". Genera una clave segura con: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=tu_api_key_segura_aqui

# --- CORS (Cross-Origin Resource Sharing) ---
# Dominios permitidos para peticiones AJAX, separados por comas.
# En producción, establece solo los dominios reales (ej: https://unifi-agent.tudominio.com).
ALLOWED_ORIGINS=http://localhost:8000

# --- Logging ---
# Nivel de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Formato: "text" para desarrollo, "json" para producción (ELK/Splunk)
LOG_FORMAT=text

# Archivo de log (se rota automáticamente)
LOG_FILE=unifi_agent.log

# Tamaño máximo por archivo de log en bytes (default: 5MB)
LOG_MAX_BYTES=5242880

# Número de backups de log a mantener (default: 5)
LOG_BACKUP_COUNT=5

# Syslog remoto (opcional). Formato: "host:port" o "/path/to/socket"
# LOG_SYSLOG_ADDRESS=192.168.1.100:514

# --- Backup automático ---
# Directorio donde se almacenan los backups de la BD
BACKUP_DIR=backups

# Días de retención de backups (default: 30)
BACKUP_RETENTION_DAYS=30

# Número máximo de backups a mantener (default: 50)
BACKUP_MAX_COUNT=50
